# Checks for primality using a miller - rabin test
def miller_rabin(n, k):

    # Checks for if the number is negative, less than 4 or even. If so, return False
    if n <= 1:
        return False
    if n < 4:
        return True
    if n % 2 == 0:
        return False

    # Turns the input n into 2^r *(d)
    r, d = 0, n - 1
    while d % 2 == 0:
        r += 1
        d //= 2

    # Runs the code k times to reduce false primes to <= 4^-k
    for i in range(k):

        # Takes a random number a as a witness
        a = random.randint(2, n - 2)

        # Stores a ^ d % n in x
        x = pow(a, d, n)
        
        # Tests x for the Miller Rabin test
        if x == 1 or x == n - 1:
            continue

        # If Miller-Rabin test is failed, sqaures x, r times and if x = n-1, 
        # returns True. Else it returns False
        for j in range(r - 1):
            x = pow(x, 2, n)
            if x == n - 1:
                break
        else:
            return False
            
    return True

